<style>
:root { --navy:#0B2545; --gold:#C9A84C; --gold-light:#E8C97A; --gold-pale:#F5EDD6; --cream:#FAF8F4; --gray:#6B7280; --border:rgba(11,37,69,0.08); --vert:#22c55e; }
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:'DM Sans',sans-serif; background:var(--cream); color:var(--navy); -webkit-font-smoothing:antialiased; min-height:100vh; display:flex; flex-direction:column; }
h1,h2 { font-family:'Playfair Display',serif; }

nav { background:white; border-bottom:1px solid var(--border); padding:0 40px; height:68px; display:flex; align-items:center; justify-content:space-between; }
.nav-logo img { height:36px; width:auto; display:block; }

.hero { flex:1; display:flex; align-items:center; justify-content:center; padding:60px 24px; }
.carte { background:white; border-radius:20px; padding:56px 48px; max-width:560px; width:100%; text-align:center; box-shadow:0 8px 40px rgba(11,37,69,0.08); position:relative; overflow:hidden; }
.carte::before { content:''; position:absolute; top:0; left:0; right:0; height:4px; background:linear-gradient(90deg, var(--vert), #4ade80); }

/* Animation coche */
.check-cercle { width:80px; height:80px; border-radius:50%; background:rgba(34,197,94,0.1); display:flex; align-items:center; justify-content:center; margin:0 auto 24px;  }

.check-icon { font-size:36px; }

.titre { font-size:clamp(26px,3vw,36px); font-weight:700; color:var(--navy); margin-bottom:10px; line-height:1.1; }
.sous-titre { font-size:16px; color:var(--gray); margin-bottom:32px; line-height:1.7; font-weight:300; }

/* Détails plan */
.plan-badge { display:inline-flex; align-items:center; gap:8px; background:var(--gold-pale); border:1px solid var(--gold); color:#8B6914; font-size:12px; font-weight:700; padding:6px 16px; border-radius:20px; margin-bottom:28px; letter-spacing:0.05em; }

/* Étapes suivantes */
.etapes { text-align:left; margin-bottom:32px; }
.etapes-titre { font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:var(--gray); margin-bottom:16px; }
.etape { display:flex; align-items:flex-start; gap:14px; margin-bottom:14px; }
.etape-num { width:28px; height:28px; border-radius:50%; background:var(--navy); color:white; font-size:12px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:1px; }
.etape-texte { font-size:14px; color:var(--navy); line-height:1.6; }
.etape-texte strong { font-weight:600; }
.etape-texte span { font-size:12px; color:var(--gray); display:block; margin-top:2px; }

.btn-dashboard { display:block; width:100%; background:var(--gold); color:var(--navy); padding:16px; border-radius:8px; font-size:15px; font-weight:700; text-decoration:none; transition:all 0.2s; margin-bottom:12px; }
.btn-dashboard:hover { background:var(--gold-light); transform:translateY(-2px); box-shadow:0 8px 24px rgba(201,168,76,0.3); }

.garanties { display:flex; justify-content:center; gap:20px; flex-wrap:wrap; margin-top:8px; }
.garantie { font-size:12px; color:var(--gray); display:flex; align-items:center; gap:4px; }
.garantie::before { content:'✓'; color:var(--vert); font-weight:700; }



footer { background:#0A1A3D; padding:28px 40px; text-align:center; }
footer p { font-size:12px; color:rgba(255,255,255,0.2); }
footer a { color:rgba(255,255,255,0.3); text-decoration:none; margin:0 8px; }
footer a:hover { color:var(--gold); }

@media(max-width:640px) { nav { padding:0 20px; } .carte { padding:40px 24px; } }
</style>
</head>
